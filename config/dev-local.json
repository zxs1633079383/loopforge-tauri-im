  "_note": "开发态 profile（debug 构建默认选此）。含本地联调真 creds，仅本地使用——禁拷进 prod.json。后端=cses-im-server(:8066·自包含 PG/Redis/Pulsar)·HTTP 前缀 /api/cses + WS /api/v4/websocket 与旧 mattermost 一致·仅端口 8065→8066。切流 spec：docs/cutover/。",
  "apiBase": "http://localhost:8066/api/cses",
  "wsUrl": "ws://localhost:8066/api/v4/websocket",
  "companyId": "64118eebd2b665246b7880eb",
  "cookieId": "444",
  "deviceId": "ED380414932542BAB4993E5AC3E07C64",
  "observability": {
    "otel": {
      "enabled": true,
      "serviceName": "loopforge-tauri-im",
      "endpoint": "http://opentelemetry-collector.monitoring.svc.cluster.local:4317",
      "protocol": "grpc",
      "sampler": {
        "type": "parentbased_traceidratio",
        "ratio": 1.0
      },
      "facets": {
        "client": true,
        "tauri": true,
        "core": true,
        "http": true,
        "ws": true,
        "storage": true,
        "event": true,
        "render": true
      },
      "jaegerQueryUrl": "http://192.168.6.66:32281",
      "capture": {
        "enabled": true,
        "maxBodyBytes": 65536,
        "maxHeaderBytes": 16384,
        "http": {
          "headers": {
            "include": [".*"],
            "exclude": []
          },
          "requestBody": {
            "includePath": [".*"],
            "excludePath": []
          }
        },
        "ws": {
          "actions": {
            "include": [".*"],
            "exclude": []
          },
          "payload": {
            "include": [".*"],
            "exclude": []
          }
        },
        "redact": {
          "headers": ["(?i)^authorization$", "(?i)^cookie$", "(?i)^set-cookie$"],
          "jsonPaths": ["$.password", "$.token", "$.accessToken", "$.refreshToken"]
        }
      }
    }
  }
