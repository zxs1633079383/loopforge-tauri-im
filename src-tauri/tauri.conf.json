{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "loopforge-tauri-im",
  "version": "0.1.0",
  "identifier": "com.mac28.loopforge-tauri-im",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist/loopforge-tauri-im/browser"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LoopForge IM",
        "width": 900,
        "height": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
